# build output
dist/

# generated types
.astro/

# dependencies
node_modules/

# There is one lockfile and it lives at the root (ADR 0006, ARCHITECTURE §5).
# Running `deno cache` / `deno run` from inside a member writes a second one
# there, resolved against that member's config rather than the workspace, and
# nothing reads it: the images and CI only ever see the root lock.
*/*/deno.lock

# The legacy MySQL dump. It holds 150 members' Discord / TeamSpeak / Steam ids,
# so it stays out of git (§7, GDPR-lite). Phase 2's import reads it from disk.
data/

# Docker Compose file-based secrets. The .example files are the committed part.
secrets/*
!secrets/*.example
!secrets/README.md

# Pre-migration pg_dumps (ADR 0013). Member PII: Discord, TeamSpeak and Steam
# ids. ADR 0011 rejected dumps-in-git for exactly this reason.
backups/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/
