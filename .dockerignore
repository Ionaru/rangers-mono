# Keep the build context small, and keep two things out of the image entirely:
#
#   node_modules/  ~276 MB, and the runtime image ships none of it by design.
#   data/          the legacy dump: 150 members' Discord / TeamSpeak / Steam ids.
#                  Personal data has no business in a build layer (§7, GDPR-lite).
node_modules/
**/node_modules/
data/
secrets/
# Every secret that is not in secrets/ is in here (ADR 0014). It has no business
# in a build context, let alone in a layer of a public GHCR image.
.env
.env.production

**/dist/
**/.astro/

.git/
.github/
.idea/
.vscode/
docs/
*.md
