{
  "name": "@7r/db",
  "version": "0.0.1",
  "exports": {
    ".": "./mod.ts"
  },
  "imports": {
    // drizzle-kit must be declared here AND nodeModulesDir must be "auto" at the
    // workspace root. Both are required, independently: without the import you
    // get `Import "drizzle-kit" not a dependency`, and without nodeModulesDir
    // you get the actively misleading "Please install latest version of
    // drizzle-orm" even though it is installed and current (ADR 0008).
    "drizzle-kit": "npm:drizzle-kit@1.0.0-rc.4",
    "@std/path": "jsr:@std/path@^1.1.6"
  },
  "tasks": {
    "generate": "deno run -A npm:drizzle-kit@1.0.0-rc.4 generate",
    // One-shot, and it should never need running again: it converts a pre-1.0
    // migrations folder (meta/_journal.json + flat .sql files) into 1.0's
    // folder-per-migration layout. Kept as a task because it is the documented
    // way back if the folder is ever restored from an old checkout.
    "up": "deno run -A npm:drizzle-kit@1.0.0-rc.4 up",
    // --env-file, on the host-side tasks only. Deno does not read `.env` on its
    // own, so without this every one of these is "export DATABASE_URL first, and
    // discover you forgot by reading a stack trace". A real environment variable
    // still beats the file, so an explicit `DATABASE_URL=... deno task migrate`
    // keeps working and CI is untouched; a missing file is a warning, not an
    // error. The containers never reach this: compose overrides the command and
    // gets DATABASE_URL from the mounted secret instead (ADR 0014).
    "migrate": "deno run --allow-net --allow-env --allow-read --allow-sys --env-file=../../.env migrate.ts",
    "import:legacy": "deno run --allow-net --allow-env --allow-read --allow-sys --env-file=../../.env import-legacy.ts"
  }
}
