---
/**
 * The public homepage. SSR (not prerendered) so the header can greet a signed-in
 * member; it is on the middleware's public path, so signed-out visitors reach it
 * fine. This replaces the Phase 2 placeholder sign-in page (ARCHITECTURE §9);
 * signing in now lives in the header (PublicLayout).
 */
import PublicLayout from "../layouts/PublicLayout.astro";

const member = Astro.locals.member;

const pillars = [
  {
    kicker: "Reference",
    title: "The Handbook",
    body:
      "Techniques, tactics and procedures, from your first mission to combined arms, aviation and armour. Read it before you deploy.",
    href: "/handbook/",
    go: "Open the handbook",
  },
  {
    kicker: "Tool",
    title: "Briefing Generator",
    body:
      "Write a mission briefing and export it straight to Arma 3 SQF. The same tool our mission makers use.",
    href: "/briefing-generator",
    go: "Build a briefing",
  },
  {
    kicker: "The unit",
    title: "About the 7th",
    body:
      "How the unit is structured, how an operation runs, and what we ask of you. Start here if you're thinking of joining.",
    href: "/about",
    go: "About the unit",
  },
];
---
<PublicLayout title="Home" current="home" member={member}>
  <section class="hero">
    <div class="hero__bg"
      style="background-image:url(/brand/background.webp)"></div>
    <div class="hero__scrim"></div>
    <div class="wrap">
      <div class="hero__inner">
        <p class="eyebrow">European Arma 3 milsim</p>
        <h1>
          <img
            class="hero__wordmark"
            src="/brand/banner.png"
            alt="7th Ranger Group"
            width="1030"
            height="150"
          />
        </h1>
        <p class="lede hero__lede">
          One operation every Saturday night: planned, briefed and debriefed,
          and played by people who take the mission seriously and themselves
          lightly.
        </p>
        <div class="hero__actions">
          <a class="btn btn--primary" href="/about">How to join</a>
          <a class="btn btn--ghost" href="/handbook/">Read the handbook</a>
        </div>
        <div class="hero__meta">
          <span>Saturdays · 20:00 CET/CEST</span>
          <span>TeamSpeak + ACRE2</span>
          <span>Arma 3</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow">Who we are</p>
        <h2 class="h-section">A unit, not a pickup server</h2>
        <p>
          The 7th Ranger Group is an international Arma 3 milsim community, based
          in Europe with members from all over. We're not a drop-in server:
          we're a standing unit built on planning, communication and adapted
          military tactics, running one operation a week. You'll know your team,
          your callsign and your job.
        </p>
      </div>
      <dl class="facts">
        <div class="fact">
          <dt>Cadence</dt>
          <dd>One operation every Saturday, 20:00-23:00 CET/CEST.</dd>
        </div>
        <div class="fact">
          <dt>Comms</dt>
          <dd>TeamSpeak with ACRE2 radio, and the net discipline to match.</dd>
        </div>
        <div class="fact">
          <dt>Progression</dt>
          <dd>Skills and qualifications you earn at your own pace, mentored the whole way.</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="section section--panel">
    <div class="wrap take">
      <div class="video">
        <iframe
          src="https://www.youtube.com/embed?max-results=1&showinfo=0&rel=0&listType=user_uploads&list=maalescrap"
          title="7th Ranger Group on YouTube"
          loading="lazy"
          allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen></iframe>
      </div>
      <div class="take__text">
        <p class="eyebrow">Our take on milsim</p>
        <h2 class="h-section">Serious where it counts</h2>
        <p>
          We lean into the simulation where it makes the game better and drop it
          where it doesn't. First-person only, disciplined comms and real-world
          tactics, but the player's experience comes first, and we teach every
          bit of it. Mostly infantry, but not limited to it.
        </p>
      </div>
    </div>
  </section>

  <div class="wrap">
    <hr class="rule" />
  </div>

  <section class="section">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow">Start here</p>
        <h2 class="h-section">Everything you need before you deploy</h2>
      </div>
      <div class="pillars">
        {
          pillars.map((p) => (
            <a class="pillar" href={p.href}>
              <span class="pillar__no">{p.kicker}</span>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
              <span class="pillar__go">
                {p.go} <span class="sq" aria-hidden="true" />
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="enlist">
    <div class="enlist__bg"
      style="background-image:url(/brand/group.webp)"></div>
    <div class="enlist__scrim"></div>
    <div class="wrap">
      <div class="enlist__inner">
        <p class="eyebrow">Recruiting now</p>
        <h2 class="h-section">Enlist</h2>
        <p>
          No milsim experience required. If you're 18 or over, own Arma 3, and
          you'll show up ready to listen and learn, there's a place for you.
          We'll teach you the standard.
        </p>
        <div class="hero__actions">
          <a
            class="btn btn--primary"
            href="https://discord.gg/vbFMQXe"
            rel="noopener"
          >
            Join our Discord
          </a>
          <a class="btn btn--ghost" href="/about">How it works</a>
        </div>
      </div>
    </div>
  </section>
</PublicLayout>
