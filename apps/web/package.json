    "@7r/discord": "workspace:*",
    "@7r/domain": "workspace:*",
    "@7r/identity": "workspace:*",
    "@astrojs/starlight": "0.41.3",
    "@deno/astro-adapter": "0.6.0",
    "astro": "7.0.7",
    "better-auth": "1.7.0-rc.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "typescript": "5.9.3"
  }
