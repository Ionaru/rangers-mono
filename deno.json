{
  "workspace": [
    "./packages/config",
    "./packages/domain",
    "./packages/db",
    "./packages/discord",
    "./packages/teamspeak",
    "./packages/identity",
    "./apps/web",
    "./apps/worker"
  ],
  "nodeModulesDir": "auto",
  // Deno-only tooling. npm runtime dependencies deliberately do NOT live here:
  // they go in each member's package.json, which is the only manifest Astro's
  // bundler reads. One dependency, one home.
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19"
  },
  "tasks": {
    // `deno check` cannot read .astro files, so apps/web is typechecked by
    // `astro check` instead. Both halves run, or the web app's strict tsconfig
    // is enforced nowhere outside an editor and `astro build` only transpiles.
    "check": "deno check packages/config/mod.ts packages/domain/mod.ts packages/db/mod.ts packages/db/migrate.ts packages/db/import-legacy.ts packages/discord/mod.ts packages/teamspeak/mod.ts packages/identity/mod.ts apps/worker/main.ts && deno task web:check",
    // apps/ as well as packages/. The worker's internal API is the one
    // authorisation boundary in the system, and it is pure request-handling, so
    // it is testable even though the TeamSpeak connection behind it is not.
    "test": "deno test --allow-read --allow-env --allow-write=/tmp packages/ apps/",
    "fmt": "deno fmt --unstable-component",
    "fmt:check": "deno fmt --check --unstable-component",
    "lint": "deno lint",
    "db:generate": "deno task --cwd packages/db generate",
    "migrate": "deno task --cwd packages/db migrate",
    "web:dev": "deno task --cwd apps/web dev",
    "web:build": "deno task --cwd apps/web build",
    "web:check": "deno task --cwd apps/web check",
    "web:preview": "deno task --cwd apps/web preview",
    "worker:dev": "deno task --cwd apps/worker dev"
  },
  "fmt": {
    "exclude": [
      "**/dist",
      "**/.astro",
      "packages/db/drizzle",
      "data",
      "node_modules",
      // Markdown is hand-authored prose, and the docs are the spec. deno fmt
      // reflows it, which rewrites every paragraph it touches and buries a real
      // edit in 1,800 lines of rewrapping. Formatting is for code.
      "**/*.md"
    ]
  },
  "lint": {
    "exclude": [
      "**/dist",
      "**/.astro",
      "packages/db/drizzle",
      "data",
      "node_modules"
    ],
    "rules": {
      // no-slow-types exists to keep JSR from having to infer types when it
      // publishes a package. These packages carry `name`/`exports` only so that
      // Deno's workspace resolver can find them; they are internal and will
      // never be published, so the rule is asking for annotations that buy us
      // nothing.
      "exclude": ["no-slow-types"]
    }
  },
  "exclude": ["node_modules", "**/dist", "**/.astro"]
}
